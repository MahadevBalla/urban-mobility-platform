    rdfs:domain :StopTimeUpdate ;
    rdfs:range xsd:integer .

:arrival_time a owl:DatatypeProperty ;
    rdfs:label "arrival_time" ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( :InferredTrip :StayPoint :StopTime :StopTimeUpdate ) ] ;
