    rdfs:domain :StopTimeUpdate ;
    rdfs:range xsd:integer .

:attributes a owl:DatatypeProperty ;
    rdfs:label "attributes" ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( :AgentEntity :Household :Person :SurveyHousehold :SurveyPerson ) ] ;
    rdfs:range xsd:string .

:average_speed_kmh a owl:DatatypeProperty ;
    rdfs:label "average_speed_kmh" ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( :ODTrajectory :SpeedObservation ) ] ;
    rdfs:range xsd:float .

:average_travel_time_minutes a owl:DatatypeProperty ;
    rdfs:label "average_travel_time_minutes" ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( :ODPair :ODMatrix_Mobile ) ] ;
    rdfs:range xsd:float .

:azimuth_degrees a owl:DatatypeProperty ;
    rdfs:label "azimuth_degrees" ;
