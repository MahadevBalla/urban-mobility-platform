# ==================================================
# PROPERTIES (from dataclass fields)
# ==================================================

:absolute_error a owl:DatatypeProperty ;
    rdfs:label "absolute_error" ;
    rdfs:domain :ControlTotal ;
    rdfs:range xsd:integer .

:acceleration_mps2 a owl:DatatypeProperty ;
    rdfs:label "acceleration_mps2" ;
    rdfs:domain :GPSTracePoint ;
    rdfs:range xsd:float .

:access a owl:DatatypeProperty ;
    rdfs:label "access" ;
    rdfs:domain :RoadSegment ;
    rdfs:range xsd:string .

:accuracy_m a owl:DatatypeProperty ;
    rdfs:label "accuracy_m" ;
    rdfs:domain :GPSTracePoint ;
    rdfs:range xsd:float .

:achieved_value a owl:DatatypeProperty ;
    rdfs:label "achieved_value" ;
    rdfs:domain :ControlTotal ;
    rdfs:range xsd:integer .

:active_period_end a owl:DatatypeProperty ;
    rdfs:label "active_period_end" ;
    rdfs:domain :ServiceAlert ;
    rdfs:range xsd:dateTime .

:active_period_start a owl:DatatypeProperty ;
    rdfs:label "active_period_start" ;
    rdfs:domain :ServiceAlert ;
    rdfs:range xsd:dateTime .

:activities a owl:DatatypeProperty ;
    rdfs:label "activities" ;
    rdfs:domain :TripChain ;
    rdfs:range rdf:List .

:activity_category a owl:DatatypeProperty ;
    rdfs:label "activity_category" ;
    rdfs:domain :Activity ;
    rdfs:range xsd:string .

:activity_id a owl:DatatypeProperty ;
    rdfs:label "activity_id" ;
    rdfs:domain :Activity ;
    rdfs:range xsd:string .

:activity_num a owl:DatatypeProperty ;
    rdfs:label "activity_num" ;
    rdfs:domain :Activity ;
    rdfs:range xsd:integer .

:activity_type a owl:DatatypeProperty ;
    rdfs:label "activity_type" ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( :Activity :StayPoint ) ] ;
    rdfs:range xsd:string .

:addr_city a owl:DatatypeProperty ;
    rdfs:label "addr_city" ;
    rdfs:domain :Building ;
    rdfs:range xsd:string .

:addr_housenumber a owl:DatatypeProperty ;
    rdfs:label "addr_housenumber" ;
    rdfs:domain :Building ;
    rdfs:range xsd:string .

:addr_postcode a owl:DatatypeProperty ;
    rdfs:label "addr_postcode" ;
    rdfs:domain :Building ;
    rdfs:range xsd:string .

:addr_street a owl:DatatypeProperty ;
    rdfs:label "addr_street" ;
    rdfs:domain :Building ;
    rdfs:range xsd:string .

:address a owl:DatatypeProperty ;
    rdfs:label "address" ;
    rdfs:domain :Location ;
    rdfs:range xsd:string .

:affected_routes a owl:DatatypeProperty ;
    rdfs:label "affected_routes" ;
    rdfs:domain :ServiceAlert ;
    rdfs:range rdf:List .

:affected_stops a owl:DatatypeProperty ;
    rdfs:label "affected_stops" ;
    rdfs:domain :ServiceAlert ;
    rdfs:range rdf:List .

:affected_trips a owl:DatatypeProperty ;
    rdfs:label "affected_trips" ;
    rdfs:domain :ServiceAlert ;
    rdfs:range rdf:List .

:age a owl:DatatypeProperty ;
    rdfs:label "age" ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( :Person :SurveyPerson ) ] ;
    rdfs:range xsd:integer .

:agency_email a owl:DatatypeProperty ;
    rdfs:label "agency_email" ;
    rdfs:domain :Agency ;
    rdfs:range xsd:string .

:agency_fare_url a owl:DatatypeProperty ;
    rdfs:label "agency_fare_url" ;
    rdfs:domain :Agency ;
    rdfs:range xsd:string .

:agency_id a owl:DatatypeProperty ;
    rdfs:label "agency_id" ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( :Agency :Route ) ] ;
    rdfs:range xsd:string .

:agency_lang a owl:DatatypeProperty ;
    rdfs:label "agency_lang" ;
    rdfs:domain :Agency ;
    rdfs:range xsd:string .

:agency_name a owl:DatatypeProperty ;
    rdfs:label "agency_name" ;
    rdfs:domain :Agency ;
    rdfs:range xsd:string .

:agency_phone a owl:DatatypeProperty ;
    rdfs:label "agency_phone" ;
    rdfs:domain :Agency ;
    rdfs:range xsd:string .

:agency_timezone a owl:DatatypeProperty ;
    rdfs:label "agency_timezone" ;
    rdfs:domain :Agency ;
    rdfs:range xsd:string .

:agency_url a owl:DatatypeProperty ;
    rdfs:label "agency_url" ;
    rdfs:domain :Agency ;
    rdfs:range xsd:string .

:agent_category a owl:DatatypeProperty ;
    rdfs:label "agent_category" ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( :AgentEntity :Household :Person :SurveyHousehold :SurveyPerson ) ] ;
    rdfs:range xsd:string .

:agent_name a owl:DatatypeProperty ;
    rdfs:label "agent_name" ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( :AgentEntity :Household :Person :SurveyHousehold :SurveyPerson ) ] ;
    rdfs:range xsd:string .

:alert_id a owl:DatatypeProperty ;
    rdfs:label "alert_id" ;
    rdfs:domain :ServiceAlert ;
    rdfs:range xsd:string .

:altitude_m a owl:DatatypeProperty ;
    rdfs:label "altitude_m" ;
    rdfs:domain :GPSTracePoint ;
    rdfs:range xsd:float .

:amenity a owl:DatatypeProperty ;
    rdfs:label "amenity" ;
    rdfs:domain :PointOfInterest ;
    rdfs:range xsd:string .

:anchor_location a owl:DatatypeProperty ;
    rdfs:label "anchor_location" ;
    rdfs:domain :Tour ;
    rdfs:range xsd:string .

:anon_user_id a owl:DatatypeProperty ;
    rdfs:label "anon_user_id" ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( :AnonymizedUser :CDREvent :InferredTrip :StayPoint ) ] ;
    rdfs:range xsd:string .

:area_km2 a owl:DatatypeProperty ;
    rdfs:label "area_km2" ;
    rdfs:domain :Zone ;
    rdfs:range xsd:float .

:area_land_km2 a owl:DatatypeProperty ;
